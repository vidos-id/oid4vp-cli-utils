{
	"client_id": "https://verifier.example/pid-basic",
	"nonce": "pid-basic-nonce",
	"response_type": "vp_token",
	"dcql_query": {
		"credentials": [
			{
				"id": "pid",
				"format": "dc+sd-jwt",
				"meta": {
					"vct_values": ["urn:eudi:pid:1"]
				},
				"claims": [
					{
						"path": ["given_name"]
					},
					{
						"path": ["family_name"]
					},
					{
						"path": ["birthdate"]
					},
					{
						"path": ["nationalities"]
					}
				]
			}
		]
	}
}
